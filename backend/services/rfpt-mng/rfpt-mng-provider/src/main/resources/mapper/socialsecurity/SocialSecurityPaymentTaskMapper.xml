<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zy.rfpt.mng.provider.infrastructure.persistence.socialsecurity.mapper.SocialSecurityPaymentTaskMapper">
    <resultMap id="TaskMap" type="com.zy.rfpt.mng.provider.infrastructure.persistence.socialsecurity.entity.SocialSecurityPaymentTaskEntity">
        <id property="id" column="id"/>
        <result property="batchId" column="batch_id"/>
        <result property="taxNo" column="tax_no"/>
        <result property="enterpriseName" column="enterprise_name"/>
        <result property="securityAccountName" column="security_account_name"/>
        <result property="regionCode" column="region_code"/>
        <result property="siteType" column="site_type"/>
        <result property="periodMonth" column="period_month"/>
        <result property="status" column="status"/>
        <result property="payableAmount" column="payable_amount"/>
        <result property="errorCode" column="error_code"/>
        <result property="errorMessage" column="error_message"/>
        <result property="retryable" column="retryable"/>
        <result property="retryCount" column="retry_count"/>
        <result property="maxRetryCount" column="max_retry_count"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="TaskWhere">
        <where>
            <if test="query.batchId != null">
                AND t.batch_id = #{query.batchId}
            </if>
            <if test="query.taxNo != null and query.taxNo != ''">
                AND t.tax_no = #{query.taxNo}
            </if>
            <if test="query.status != null and query.status != ''">
                AND t.status = #{query.status}
            </if>
        </where>
    </sql>

    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_tax_social_security_payment_task
        (batch_id, tax_no, region_code, site_type, period_month, status, retryable, retry_count, max_retry_count, created_by, created_at, updated_at)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.batchId}, #{item.taxNo}, #{item.regionCode}, #{item.siteType}, #{item.periodMonth}, #{item.status}, #{item.retryable}, #{item.retryCount}, #{item.maxRetryCount}, #{item.createdBy}, #{item.createdAt}, #{item.updatedAt})
        </foreach>
    </insert>

    <select id="findById" resultMap="TaskMap">
        SELECT t.*, e.enterprise_name, e.security_account_name
        FROM tb_tax_social_security_payment_task t
        LEFT JOIN tb_tax_enterprise e ON e.tax_no = t.tax_no
        WHERE t.id = #{id}
    </select>

    <update id="markRetry">
        UPDATE tb_tax_social_security_payment_task
        SET status = 'PENDING', retryable = 0, retry_count = retry_count + 1,
            error_code = NULL, error_message = NULL, updated_at = NOW(), updated_by = #{operator}
        WHERE id = #{id}
    </update>

    <select id="count" resultType="long">
        SELECT COUNT(1)
        FROM tb_tax_social_security_payment_task t
        <include refid="TaskWhere"/>
    </select>

    <select id="page" resultMap="TaskMap">
        SELECT t.*, e.enterprise_name, e.security_account_name
        FROM tb_tax_social_security_payment_task t
        LEFT JOIN tb_tax_enterprise e ON e.tax_no = t.tax_no
        <include refid="TaskWhere"/>
        ORDER BY t.id DESC
        LIMIT #{offset}, #{limit}
    </select>
</mapper>

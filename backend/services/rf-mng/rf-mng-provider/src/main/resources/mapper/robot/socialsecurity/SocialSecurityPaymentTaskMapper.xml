<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rf.mng.provider.infrastructure.persistence.robot.socialsecurity.mapper.SocialSecurityPaymentTaskMapper">
    <resultMap id="TaskMap" type="com.rf.mng.provider.infrastructure.persistence.socialsecurity.entity.SocialSecurityPaymentTaskEntity">
        <id property="id" column="id"/>
        <result property="batchId" column="batch_id"/>
        <result property="taxNo" column="tax_no"/>
        <result property="enterpriseName" column="enterprise_name"/>
        <result property="securityAccountName" column="security_account_name"/>
        <result property="regionCode" column="region_code"/>
        <result property="periodMonth" column="settle_month"/>
        <result property="status" column="task_status"/>
        <result property="payableAmount" column="tax_total_amount"/>
        <result property="errorMessage" column="error_message"/>
        <result property="retryable" column="retryable"/>
        <result property="retryCount" column="retry_count"/>
        <result property="maxRetryCount" column="max_retry_count"/>
        <result property="createAdminId" column="create_admin_id"/>
        <result property="createAdminName" column="create_admin_name"/>
        <result property="createdAt" column="gmt_create"/>
        <result property="updatedAt" column="gmt_modified"/>
    </resultMap>

    <sql id="TaskWhere">
        <where>
            <if test="query.batchId != null">
                AND batch_id = #{query.batchId}
            </if>
            <if test="query.taxNo != null and query.taxNo != ''">
                AND tax_no = #{query.taxNo}
            </if>
            <if test="query.status != null and query.status != ''">
                AND task_status = #{query.status}
            </if>
        </where>
    </sql>

    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_tax_social_security_payment_task
        (batch_id, tax_no, region_code, settle_month, task_status, retryable, retry_count, max_retry_count, create_admin_id, create_admin_name)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.batchId}, #{item.taxNo}, #{item.regionCode}, #{item.periodMonth}, #{item.status}, #{item.retryable}, #{item.retryCount}, #{item.maxRetryCount}, #{item.createAdminId}, #{item.createAdminName})
        </foreach>
    </insert>

    <select id="findById" resultMap="TaskMap">
        SELECT *
        FROM tb_tax_social_security_payment_task
        WHERE id = #{id}
    </select>

    <update id="markRetry">
        UPDATE tb_tax_social_security_payment_task
        SET task_status = 'PROCESSING', retryable = 0, retry_count = retry_count + 1,
            error_message = NULL
        WHERE id = #{id}
    </update>

    <select id="count" resultType="long">
        SELECT COUNT(1)
        FROM tb_tax_social_security_payment_task
        <include refid="TaskWhere"/>
    </select>

    <select id="page" resultMap="TaskMap">
        SELECT *
        FROM tb_tax_social_security_payment_task
        <include refid="TaskWhere"/>
        ORDER BY id DESC
        LIMIT #{offset}, #{limit}
    </select>
</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rf.mng.provider.infrastructure.persistence.robot.socialsecurity.mapper.SocialSecurityPaymentTaskMapper">
    <resultMap id="TaskMap" type="com.rf.mng.provider.infrastructure.persistence.socialsecurity.entity.SocialSecurityPaymentTaskEntity">
        <id property="id" column="id"/>
        <result property="batchId" column="batch_id"/>
        <result property="taxNo" column="tax_no"/>
        <result property="enterpriseName" column="enterprise_name"/>
        <result property="securityAccountName" column="security_account_name"/>
        <result property="regionCode" column="region_code"/>
        <result property="siteType" column="site_type"/>
        <result property="periodMonth" column="settle_month"/>
        <result property="status" column="task_status"/>
        <result property="payableAmount" column="tax_total_amount"/>
        <result property="wpmTotalAmount" column="wpm_total_amount"/>
        <result property="compareStatus" column="compare_status"/>
        <result property="paymentStatus" column="payment_status"/>
        <result property="certificateStatus" column="certificate_status"/>
        <result property="bmsFeedbackStatus" column="bms_feedback_status"/>
        <result property="bmsFeedbackStage" column="bms_feedback_stage"/>
        <result property="bmsFeedbackErrorMessage" column="bms_feedback_error_message"/>
        <result property="diagnosticDir" column="diagnostic_dir"/>
        <result property="errorMessage" column="error_message"/>
        <result property="retryable" column="retryable"/>
        <result property="retryCount" column="retry_count"/>
        <result property="maxRetryCount" column="max_retry_count"/>
        <result property="workerId" column="worker_id"/>
        <result property="claimedAt" column="claimed_at"/>
        <result property="heartbeatAt" column="heartbeat_at"/>
        <result property="startedAt" column="started_at"/>
        <result property="finishedAt" column="finished_at"/>
        <result property="resultPayload" column="result_body"/>
        <result property="compareResultPayload" column="compare_result_json"/>
        <result property="paymentResultPayload" column="payment_result_json"/>
        <result property="certificateResultPayload" column="certificate_result_json"/>
        <result property="bmsFeedbackResultPayload" column="bms_feedback_result_json"/>
        <result property="createAdminId" column="create_admin_id"/>
        <result property="createAdminName" column="create_admin_name"/>
        <result property="gmtCreate" column="gmt_create"/>
        <result property="gmtModified" column="gmt_modified"/>
    </resultMap>

    <resultMap id="TaskSummaryMap" type="com.rf.mng.provider.infrastructure.persistence.socialsecurity.entity.SocialSecurityPaymentTaskSummaryEntity">
        <id property="batchId" column="batch_id"/>
        <result property="totalCount" column="total_count"/>
        <result property="pendingCount" column="pending_count"/>
        <result property="processingCount" column="processing_count"/>
        <result property="successCount" column="success_count"/>
        <result property="failedCount" column="failed_count"/>
        <result property="canceledCount" column="canceled_count"/>
    </resultMap>

    <sql id="TaskWhere">
        <where>
            <if test="query.batchId != null">
                AND batch_id = #{query.batchId}
            </if>
            <if test="query.taxNo != null and query.taxNo != ''">
                AND tax_no = #{query.taxNo}
            </if>
            <if test="query.status != null and query.status != ''">
                AND task_status = #{query.status}
            </if>
        </where>
    </sql>

    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_tax_social_security_payment_task
        (batch_id, tax_no, region_code, site_type, settle_month, task_status, retryable, retry_count, max_retry_count, create_admin_id, create_admin_name)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.batchId}, #{item.taxNo}, #{item.regionCode}, #{item.siteType}, #{item.periodMonth}, #{item.status}, #{item.retryable}, #{item.retryCount}, #{item.maxRetryCount}, #{item.createAdminId}, #{item.createAdminName})
        </foreach>
    </insert>

    <select id="findById" resultMap="TaskMap">
        SELECT *
        FROM tb_tax_social_security_payment_task
        WHERE id = #{id}
    </select>

    <update id="markRetry">
        UPDATE tb_tax_social_security_payment_task
        SET task_status = 'PENDING', retryable = 0, retry_count = retry_count + 1,
            worker_id = NULL, claimed_at = NULL, heartbeat_at = NULL, started_at = NULL, finished_at = NULL,
            error_message = NULL, result_body = NULL
        WHERE id = #{id}
          AND retry_count &lt; max_retry_count
    </update>

    <select id="listSummaryByBatchIds" resultMap="TaskSummaryMap">
        SELECT batch_id,
               COUNT(1) AS total_count,
               SUM(CASE WHEN task_status = 'PENDING' THEN 1 ELSE 0 END) AS pending_count,
               SUM(CASE WHEN task_status = 'PROCESSING' THEN 1 ELSE 0 END) AS processing_count,
               SUM(CASE WHEN task_status = 'SUCCESS' THEN 1 ELSE 0 END) AS success_count,
               SUM(CASE WHEN task_status = 'FAILED' THEN 1 ELSE 0 END) AS failed_count,
               SUM(CASE WHEN task_status = 'CANCELED' THEN 1 ELSE 0 END) AS canceled_count
        FROM tb_tax_social_security_payment_task
        WHERE batch_id IN
        <foreach collection="batchIds" item="batchId" open="(" separator="," close=")">
            #{batchId}
        </foreach>
        GROUP BY batch_id
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(1)
        FROM tb_tax_social_security_payment_task
        <include refid="TaskWhere"/>
    </select>

    <select id="page" resultMap="TaskMap">
        SELECT *
        FROM tb_tax_social_security_payment_task
        <include refid="TaskWhere"/>
        ORDER BY id DESC
        LIMIT #{offset}, #{limit}
    </select>
</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rf.mng.provider.infrastructure.persistence.platform.performance.mapper.EmployeePerformanceImportUploadMapper">
    <resultMap id="UploadMap" type="com.rf.mng.provider.infrastructure.persistence.performance.entity.EmployeePerformanceImportUploadEntity">
        <id property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="taskName" column="task_name"/>
        <result property="fileName" column="file_name"/>
        <result property="originalContentType" column="original_content_type"/>
        <result property="originalFileContent" column="original_file_content"/>
        <result property="failureFileName" column="failure_file_name"/>
        <result property="failureFileContent" column="failure_file_content"/>
        <result property="totalCount" column="total_count"/>
        <result property="successCount" column="success_count"/>
        <result property="failCount" column="fail_count"/>
        <result property="status" column="status"/>
        <result property="errorMessage" column="error_message"/>
        <result property="createAdminId" column="create_admin_id"/>
        <result property="createAdminName" column="create_admin_name"/>
        <result property="gmtCreate" column="gmt_create"/>
        <result property="gmtModified" column="gmt_modified"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_employee_performance_import_upload
        (task_id, task_name, file_name, original_content_type, original_file_content, failure_file_name, failure_file_content,
         total_count, success_count, fail_count, status, error_message, create_admin_id, create_admin_name)
        VALUES
        (#{taskId}, #{taskName}, #{fileName}, #{originalContentType}, #{originalFileContent}, #{failureFileName}, #{failureFileContent},
         #{totalCount}, #{successCount}, #{failCount}, #{status}, #{errorMessage}, #{createAdminId}, #{createAdminName})
    </insert>

    <select id="listRecent" resultMap="UploadMap">
        SELECT id, task_id, task_name, file_name, original_content_type, failure_file_name,
               total_count, success_count, fail_count, status, error_message, create_admin_id, create_admin_name,
               gmt_create, gmt_modified
        FROM tb_employee_performance_import_upload
        <where>
            <if test="taskId != null">
                AND task_id = #{taskId}
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{limit}
    </select>

    <select id="getById" resultMap="UploadMap">
        SELECT *
        FROM tb_employee_performance_import_upload
        WHERE id = #{id}
    </select>
</mapper>

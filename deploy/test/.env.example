# rf 测试环境 Docker 部署参数

# 宿主机端口
RF_MNG_PORT=18091
RF_MNG_WEB_PORT=18092

# 镜像和容器名称
RF_MNG_IMAGE=rf-mng:test
RF_MNG_WEB_IMAGE=rf-mng-web:test
RF_MNG_CONTAINER_NAME=rf-mng-test
RF_MNG_WEB_CONTAINER_NAME=rf-mng-web-test
RF_DOCKER_NETWORK=rf-test

# Spring 环境
SPRING_PROFILES_ACTIVE=test
RF_MNG_JAVA_OPTS=-Xms256m -Xmx512m
QY_NACOS_CONFIG_SERVER_ADDR=192.168.110.192:8848
QY_APPCONF_NACOS_CONFIG_GROUP=config
QY_NACOS_NAMESPACE_QY=ns-qy-appconf
QY_CONFIG_CRYPTO_SECRET_KEY=请填写配置密文解密密钥

# 数据库、tax-browser-worker、短信、Cookie 等配置放入 Nacos：
# common-backend-test.properties
# rf-mng-test.properties
# rf-performance-test.properties
